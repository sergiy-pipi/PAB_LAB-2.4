    print("\n--- Перевірка ітерації (сортування за ціною) ---")
    for item in ledger:
        print(item)

    print("\n--- Перевірка контекст-менеджера (Time-out) ---")
    with ex1 as session:
        print("Редагування даних...")
        time.sleep(2.1) # Імітація затримки
    
    print(f"Фінальний стан витрати: {ex1.status}")
